# TriageIQ — Environment Configuration
# Copy this file to .env and fill in the values.

# ── API Settings ──────────────────────────────────────────────
# Port for the FastAPI server
API_PORT=8000

# Host for the FastAPI server
API_HOST=0.0.0.0

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────────────
# API key for authenticating requests to the REST API.
# Set this to any strong random string. Clients must send:
#   X-API-Key: <your_key>  in the request header.
TRIAGEIQ_API_KEY=change-me-to-a-strong-secret-key

# ── Model Paths ───────────────────────────────────────────────
# Directory where trained model artifacts are stored.
MODEL_DIR=models

# ── MLflow ────────────────────────────────────────────────────
# URI for the MLflow tracking server.
# Use a file-based SQLite DB for local development.
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Experiment name for live API inference logging
MLFLOW_EXPERIMENT_NAME=triageiq_inference

# ── Streamlit ─────────────────────────────────────────────────
# URL of the FastAPI server (used by Streamlit to generate API examples)
API_BASE_URL=http://localhost:8000
